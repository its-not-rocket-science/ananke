# =========================
# Node / TypeScript
# =========================
node_modules/
npm-debug.log*
yarn.lock
pnpm-lock.yaml

# Build output
dist/
build/
out/

# Coverage reports
coverage/

# Vite / Vitest cache
.vite/
.vitest/

# OS junk
.DS_Store
Thumbs.db

# Logs
*.log

# Env files
.env
.env.*

# IDE
.vscode/
.idea/

# TypeScript incremental build
*.tsbuildinfo

# Optional: local temp files
*.tmp
*.bak

# Local crib notes — untracked
crib_notes.txt

# External dataset files — raw data too large and/or binary to commit.
# Only the README.md index file is tracked; actual dataset files are local-only.
# Pattern: ignore everything inside docs/unavailable-resources/ EXCEPT README.md
docs/unavailable-resources/*
!docs/unavailable-resources/README.md

# Tools
CLAUDE.md
.claude/
memory/